{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User create response schema",
  "type": "object",
  "properties": {
    "success": {
      "type": "boolean"
    },
    "data": {
      "type": "object",
      "properties": {
        "id": {
          "type": "number"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": ["string", "null"]
        },
        "address": {
          "type": ["string", "null"]
        },
        "avatar": {
          "type": ["string", "null"]
        },
        "gender": {
          "type": ["string", "null"]
        },
        "country": {
          "type": ["string", "null"]
        },
        "registered": {
          "type": ["string", "null"]
        }
      },
      "required": ["id", "firstName", "lastName", "email"]
    },
    "message": {
      "type": "string"
    }
  },
  "required": ["success", "data", "message"]
}
